# ===========================================
# ELECTRIA API - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# App Configuration
APP_NAME=electria
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Default Country
DEFAULT_COUNTRY_CODE=cl

# ===========================================
# Database (Supabase)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/electria

# ===========================================
# AI/ML APIs
# ===========================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_CHAT=claude-sonnet-4-20250514
CLAUDE_MODEL_FAST=claude-haiku-3-5-20241022
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.1

# OpenAI (Embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# Cohere (Reranking)
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-english-v3.0

# ===========================================
# Vector Database (Pinecone)
# ===========================================
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=electria-docs
PINECONE_NAMESPACE_PREFIX=cl

# ===========================================
# Object Storage (Cloudflare R2)
# ===========================================
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=electria-documents
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# ===========================================
# Task Queue (Redis/Celery)
# ===========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_...
EMAIL_FROM=ELECTRIA <noreply@electria.cl>

# ===========================================
# Payments (Stripe)
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...

# ===========================================
# Monitoring & Logging
# ===========================================
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=...

# ===========================================
# External Data Sources (Chile)
# ===========================================
COORDINADOR_API_URL=https://api.coordinador.cl
CNE_BASE_URL=https://www.cne.cl
SEC_BASE_URL=https://www.sec.cl
